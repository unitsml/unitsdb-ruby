#!/usr/bin/env ruby
# frozen_string_literal: true

require "unitsdb"
require "unitsdb/cli"

begin
  Unitsdb::Cli.start(ARGV)
rescue SystemExit => e
  # Only print if not already handled (exit code 0 = normal exit)
  # Exit code 1 from our commands is already handled, don't duplicate
  raise if e.status == 0
end
